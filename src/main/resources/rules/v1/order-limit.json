{
  "name": "Order Limit",
  "description": "Max 10 000 RUB for non-VIP users",
  "priority": 2,
  "condition": "!user.roles.stream().anyMatch(r -> r.name == 'ROLE_VIP') && order.items.stream().mapToDouble(i -> i.price * i.quantity).sum() > 10000",
  "action": {
    "handler": "blockActionHandler",
    "params": {
      "reason": "Order amount exceeds limit for regular users (10 000 RUB)"
    }
  }
}
